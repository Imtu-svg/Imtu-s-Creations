<script>
const pngFiles = [
  { name: "Oil Paint Portugal Flag", src: "oil paint portugal flag.png" },
  { name: "Bangladesh Map",          src: "bdmap.png" },
  { name: "Bangladesh Flag",         src: "bdflag.png" },
  { name: "India Flag",              src: "inflag.png" },
  { name: "India Round Flag",        src: "inround.png" },
  { name: "Portugal Flag",           src: "ptflag.png" },
  { name: "Portugal Penant Flag",    src: "ptpenant.png" },
  { name: "FB Logo",                 src: "fbl.png" },
  { name: "3D Location",             src: "3dlo.png" },
  { name: "3D Suitcase",             src: "3dsuit.png" },
  { name: "Whatsapp Logo",           src: "whatlo.png" },
  { name: "Viber Logo",              src: "viber.png" },
  { name: "Kalima",                  src: "kalima.png" },
  { name: "Eid Lantern",             src: "lantern.png" },
  { name: "Eid Banner",              src: "arabesuqe.png" },
  { name: "White Clouds",            src: "clouds.png" },
];

const portfolioItems = [
  { name: "Poster",              src: "adposter3.jpg",               type: "Poster" },
  { name: "Documents",           src: "BR.png",                      type: "Document" },
  { name: "Social Media Design", src: "https://picsum.photos/500?3", type: "Social Media" },
  { name: "Special",             src: "ramadan.jpg",                 type: "Special" },
  { name: "Creative",            src: "creative.jpg",                type: "Creative" },
];

function openViewer(src, name) {
  const existing = document.getElementById('pngViewer');
  if (existing) existing.remove();
  const viewer = document.createElement('div');
  viewer.id = 'pngViewer';
  viewer.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:9999;background:rgba(0,0,0,0.92);backdrop-filter:blur(12px);display:flex;flex-direction:column;justify-content:center;align-items:center;gap:20px;';
  viewer.innerHTML = `
    <style>
      #pngViewer img{max-width:88vw;max-height:68vh;object-fit:contain;border-radius:12px;border:1px solid #00ff8844;box-shadow:0 0 40px #00ff8833;animation:zoomInV .25s ease forwards;}
      @keyframes zoomInV{from{transform:scale(0.85);opacity:0}to{transform:scale(1);opacity:1}}
      .viewer-name{font-size:14px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,0.6);}
      .viewer-btns{display:flex;gap:14px;}
      .viewer-dl{padding:10px 28px;border:1px solid #00ff88;border-radius:10px;background:transparent;color:#00ff88;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;text-decoration:none;transition:box-shadow .3s,background .3s,transform .2s;}
      .viewer-dl:hover{background:#00ff8815;box-shadow:0 0 12px #00ff88;transform:translateY(-2px);}
      .viewer-close{padding:10px 28px;border:1px solid #ffffff33;border-radius:10px;background:transparent;color:rgba(255,255,255,0.5);font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:border-color .3s,color .3s,transform .2s;}
      .viewer-close:hover{border-color:#fff;color:#fff;transform:translateY(-2px);}
    </style>
    <img src="${src}" alt="${name}">
    <div class="viewer-name">${name}</div>
    <div class="viewer-btns">
      <a href="${src}" download="${name}.png" class="viewer-dl">⬇ Download</a>
      <button class="viewer-close" id="closeViewer">✕ Close</button>
    </div>
  `;
  document.body.appendChild(viewer);
  document.getElementById('closeViewer').addEventListener('click', () => viewer.remove());
  viewer.addEventListener('click', e => { if (e.target === viewer) viewer.remove(); });
}

function renderPngGrid(filter = '') {
  const grid = document.getElementById('pngGrid');
  const filtered = pngFiles.filter(f => f.name.toLowerCase().includes(filter.toLowerCase()));
  if (filtered.length === 0) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:rgba(255,255,255,0.3);letter-spacing:2px;font-size:13px;">No PNG found...</div>';
    return;
  }
  grid.innerHTML = filtered.map(f => `
    <div class="png-card" onclick="openViewer('${f.src}','${f.name}')">
      <div class="png-card-img-wrap">
        <img src="${f.src}" alt="${f.name}" loading="lazy">
      </div>
      <div class="png-card-info">
        <div class="png-card-name">${f.name}</div>
      </div>
    </div>
  `).join('');
}

function doSearch() {
  const q = document.getElementById('searchInput').value.trim();
  if (!q) return;
  const ql = q.toLowerCase();
  document.getElementById('siteSearchQuery').textContent = 'Showing results for: "' + q + '"';
  const results = document.getElementById('siteSearchResults');
  results.innerHTML = '';
  let total = 0;
  const matchedPngs = pngFiles.filter(f => f.name.toLowerCase().includes(ql));
  if (matchedPngs.length > 0) {
    total += matchedPngs.length;
    const sec = document.createElement('div');
    sec.innerHTML = `
      <div class="search-section-label" style="color:#00ff88;">✦ PNG Files (${matchedPngs.length})</div>
      <div class="search-mini-grid">
        ${matchedPngs.map(f => `
          <div class="search-mini-card">
            <div class="search-mini-img" onclick="openViewer('${f.src}','${f.name}')"><img src="${f.src}" alt="${f.name}" loading="lazy"></div>
            <div class="search-mini-info">
              <div class="search-mini-name">${f.name}</div>
              <a href="${f.src}" download="${f.name}.png" class="search-mini-dl">⬇ Download</a>
            </div>
          </div>`).join('')}
      </div>`;
    results.appendChild(sec);
  }
  const matchedPort = portfolioItems.filter(p => p.name.toLowerCase().includes(ql) || p.type.toLowerCase().includes(ql));
  if (matchedPort.length > 0) {
    total += matchedPort.length;
    const sec = document.createElement('div');
    sec.innerHTML = `
      <div class="search-section-label" style="color:#00ffff;">✦ Portfolio (${matchedPort.length})</div>
      <div class="search-portfolio-grid">
        ${matchedPort.map(p => `
          <div class="search-port-card">
            <div class="search-port-img"><img src="${p.src}" alt="${p.name}" loading="lazy"></div>
            <div class="search-port-info"><div class="search-port-name">${p.name}</div><div class="search-port-type">${p.type}</div></div>
          </div>`).join('')}
      </div>`;
    results.appendChild(sec);
  }
  if (total === 0) {
    results.innerHTML = `<div class="search-no-result"><div style="font-size:36px;margin-bottom:16px;">🔍</div>No results found for "${q}"</div>`;
  }
  document.getElementById('siteSearchOverlay').classList.add('open');
}

const menuBtn = document.querySelector('.menu-btn');
const menuDropdown = document.getElementById('menuDropdown');
menuBtn.addEventListener('click', () => menuDropdown.classList.toggle('open'));
document.addEventListener('click', e => {
  if (!menuBtn.contains(e.target) && !menuDropdown.contains(e.target)) menuDropdown.classList.remove('open');
});

document.querySelector('.home-btn').addEventListener('click', e => {
  e.preventDefault();
  const overlay = document.createElement('div');
  overlay.id = 'reloadOverlay';
  for (let i = 1; i <= 4; i++) { const r = document.createElement('div'); r.className = 'ring'; overlay.appendChild(r); }
  const sl = document.createElement('div'); sl.className = 'scanlines'; overlay.appendChild(sl);
  const colors = ['#00ffff','#ff00ff','#00ff88','#ffffff','#ff6600'];
  for (let i = 0; i < 20; i++) {
    const p = document.createElement('div'); p.className = 'particle';
    const angle = Math.random() * 360, dist = 80 + Math.random() * 160;
    p.style.cssText = `left:50%;top:50%;background:${colors[Math.floor(Math.random()*colors.length)]};--tx:${Math.cos(angle)*dist}px;--ty:${Math.sin(angle)*dist}px;box-shadow:0 0 6px currentColor;animation-delay:${Math.random()*0.3}s;`;
    overlay.appendChild(p);
  }
  overlay.innerHTML += `<div class="reload-core"><div class="reload-logo">IMTU'S</div><div class="reload-bar-wrap"><div class="reload-bar"></div></div><div class="reload-sub">Loading...</div></div>`;
  document.body.appendChild(overlay);
  setTimeout(() => window.location.reload(), 900);
});

document.querySelectorAll('.menu-item').forEach(btn => {
  btn.addEventListener('click', () => {
    const t = btn.textContent.trim();
    if (t === 'Log In') { document.getElementById('loginOverlay').classList.add('open'); menuDropdown.classList.remove('open'); }
    if (t === 'Contact') { document.getElementById('contactOverlay').classList.add('open'); menuDropdown.classList.remove('open'); }
  });
});

document.getElementById('closeLogin').addEventListener('click', () => document.getElementById('loginOverlay').classList.remove('open'));
document.getElementById('loginOverlay').addEventListener('click', e => { if (e.target === document.getElementById('loginOverlay')) document.getElementById('loginOverlay').classList.remove('open'); });
document.getElementById('closeContact').addEventListener('click', () => document.getElementById('contactOverlay').classList.remove('open'));
document.getElementById('contactOverlay').addEventListener('click', e => { if (e.target === document.getElementById('contactOverlay')) document.getElementById('contactOverlay').classList.remove('open'); });

const pngOverlay = document.getElementById('pngOverlay');
document.querySelectorAll('.cat-btn').forEach(btn => {
  if (btn.textContent.trim() === 'Png') {
    btn.addEventListener('click', () => { pngOverlay.classList.add('open'); renderPngGrid(); });
  }
});
document.getElementById('closePng').addEventListener('click', () => pngOverlay.classList.remove('open'));
pngOverlay.addEventListener('click', e => { if (e.target === pngOverlay) pngOverlay.classList.remove('open'); });
document.getElementById('pngSearch').addEventListener('input', e => renderPngGrid(e.target.value));

document.getElementById('closeSiteSearch').addEventListener('click', () => document.getElementById('siteSearchOverlay').classList.remove('open'));
document.getElementById('siteSearchOverlay').addEventListener('click', e => { if (e.target === document.getElementById('siteSearchOverlay')) document.getElementById('siteSearchOverlay').classList.remove('open'); });

const input = document.getElementById('searchInput');
const wrapper = document.getElementById('searchWrapper');
input.addEventListener('focus', () => wrapper.classList.add('active'));
input.addEventListener('blur', () => wrapper.classList.remove('active'));
input.addEventListener('keydown', e => { if (e.key === 'Enter') doSearch(); });
wrapper.addEventListener('mouseenter', () => wrapper.classList.add('active'));
wrapper.addEventListener('mouseleave', () => { if (document.activeElement !== input) wrapper.classList.remove('active'); });
document.getElementById('voiceBtn').addEventListener('click', () => window.open('https://www.google.com/search?q=&gs_ivs=1','_blank'));
document.getElementById('lensBtn').addEventListener('click', () => window.open('https://lens.google.com/search?p=','_blank'));
</script>
