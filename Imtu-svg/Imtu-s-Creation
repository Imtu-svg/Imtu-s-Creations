<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title> IMTU'S Creations </title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,Helvetica,sans-serif;}
body{color:white;overflow-x:hidden;background:radial-gradient(circle at center,#3a3a3a 0%,#0b0b0b 60%,#000 100%);}

.home-btn{position:fixed;top:25px;left:25px;width:100px;cursor:pointer;z-index:2000;transition:.3s;}
.home-btn:hover{animation:glitch .5s infinite;transform:scale(1.15) rotate(-5deg);}

#reloadOverlay{position:fixed;inset:0;z-index:9999;display:flex;justify-content:center;align-items:center;background:#000;overflow:hidden;animation:fadeInOverlay 0.3s ease forwards;}
@keyframes fadeInOverlay{from{opacity:0}to{opacity:1}}
.ring{position:absolute;border-radius:50%;border:2px solid transparent;animation:shockwave 1s ease-out forwards;}
.ring:nth-child(1){border-color:#00ffff;animation-delay:0s;}
.ring:nth-child(2){border-color:#ff00ff;animation-delay:0.2s;}
.ring:nth-child(3){border-color:#ffffff;animation-delay:0.4s;}
.ring:nth-child(4){border-color:#00ff88;animation-delay:0.6s;}
@keyframes shockwave{0%{width:0px;height:0px;opacity:1;box-shadow:0 0 10px currentColor}100%{width:900px;height:900px;opacity:0;box-shadow:0 0 60px currentColor}}
.reload-core{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;gap:20px;}
.reload-logo{font-size:52px;font-weight:900;letter-spacing:8px;background:linear-gradient(90deg,#00ffff,#ff00ff,#ffffff,#00ff88,#00ffff);background-size:300% 300%;-webkit-background-clip:text;color:transparent;animation:gradientShift 1s linear infinite,zoomIn 0.4s ease forwards,glitchFlicker 1.5s steps(2) infinite;}
@keyframes gradientShift{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes zoomIn{from{transform:scale(0.5);opacity:0}to{transform:scale(1);opacity:1}}
@keyframes glitchFlicker{0%,100%{text-shadow:3px 0 #ff00ff,-3px 0 #00ffff}25%{text-shadow:-3px 0 #ff00ff,3px 0 #00ffff}50%{text-shadow:3px 3px #00ff88,-3px -3px #ff00ff}75%{text-shadow:0 0 20px #fff,3px 0 #00ffff}}
.scanlines{position:absolute;inset:0;background:repeating-linear-gradient(to bottom,transparent 0px,transparent 3px,rgba(255,255,255,0.03) 3px,rgba(255,255,255,0.03) 4px);pointer-events:none;z-index:1;}
.particle{position:absolute;width:4px;height:4px;border-radius:50%;animation:floatParticle 1s ease-out forwards;}
@keyframes floatParticle{0%{transform:translate(0,0) scale(1);opacity:1}100%{transform:translate(var(--tx),var(--ty)) scale(0);opacity:0}}
.reload-bar-wrap{width:220px;height:3px;background:rgba(255,255,255,0.1);border-radius:10px;overflow:hidden;}
.reload-bar{height:100%;width:0%;border-radius:10px;background:linear-gradient(90deg,#00ffff,#ff00ff,#00ff88);animation:loadBar 1s ease forwards;box-shadow:0 0 10px #00ffff;}
@keyframes loadBar{0%{width:0%}60%{width:80%}100%{width:100%}}
.reload-sub{font-size:13px;letter-spacing:5px;text-transform:uppercase;color:rgba(255,255,255,0.4);}

.menu-btn{position:fixed;top:25px;right:25px;width:80px;cursor:pointer;z-index:2000;transition:.3s;}
.menu-btn:hover{animation:glitch .5s infinite;transform:scale(1.15) rotate(5deg);}
.menu-dropdown{position:fixed;top:115px;right:30px;display:flex;flex-direction:column;gap:12px;z-index:1999;opacity:0;pointer-events:none;transform:translateY(-10px);transition:opacity 0.3s,transform 0.3s;}
.menu-dropdown.open{opacity:1;pointer-events:all;transform:translateY(0);}
.menu-item{background:transparent;color:#00ffff;border:1px solid #00ffff44;border-radius:8px;padding:10px 28px;font-size:15px;font-weight:600;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:color 0.3s,border-color 0.3s,box-shadow 0.3s,transform 0.2s;backdrop-filter:blur(6px);position:relative;overflow:hidden;}
.menu-item::before{content:'';position:absolute;inset:0;background:#00ffff;opacity:0;transform:scaleX(0);transform-origin:left;transition:transform 0.35s ease,opacity 0.35s ease;z-index:0;}
.menu-item:hover::before{transform:scaleX(1);opacity:0.12;}
.menu-item:hover{border-color:#00ffff;box-shadow:0 0 8px #00ffff,0 0 20px #00ffff88,0 0 40px #00ffff44,inset 0 0 12px #00ffff22;color:#88ffff;transform:translateY(-3px);}
.menu-item:active{transform:translateY(0px) scale(0.97);}

.popup-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.75);backdrop-filter:blur(6px);z-index:8000;display:flex;justify-content:center;align-items:center;opacity:0;pointer-events:none;transition:opacity 0.3s;}
.popup-overlay.open{opacity:1;pointer-events:all;}
.login-popup{background:#111;border:1px solid #00ffff33;border-radius:16px;padding:40px 36px;width:340px;display:flex;flex-direction:column;align-items:center;gap:18px;position:relative;box-shadow:0 0 40px #00ffff22,0 0 80px #ff00ff11;transform:scale(0.9);transition:transform 0.3s;}
.popup-overlay.open .login-popup{transform:scale(1);}
.popup-bottom-btns{display:flex;gap:12px;width:100%;margin-top:4px;}
.popup-ghost-btn{flex:1;padding:10px;border:1px solid #00ffff44;border-radius:8px;background:transparent;color:#00ffff;font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:box-shadow 0.3s,border-color 0.3s,color 0.3s,transform 0.2s;}
.popup-ghost-btn:hover{border-color:#00ffff;box-shadow:0 0 8px #00ffff,0 0 20px #00ffff88,inset 0 0 12px #00ffff22;color:#88ffff;transform:translateY(-2px);}
.popup-close{position:absolute;top:14px;right:16px;background:transparent;border:none;color:rgba(255,255,255,0.4);font-size:18px;cursor:pointer;transition:color 0.2s;}
.popup-close:hover{color:#00ffff;}
.popup-logo{width:80px;border-radius:50%;object-fit:cover;}
.popup-title{font-size:20px;font-weight:700;letter-spacing:3px;text-transform:uppercase;background:linear-gradient(90deg,#00ffff,#ff00ff);-webkit-background-clip:text;color:transparent;}
.input-group{width:100%;}
.popup-input{width:100%;background:#1a1a1a;border:1px solid #ffffff22;border-radius:8px;padding:12px 16px;font-size:14px;color:#fff;outline:none;transition:border-color 0.3s,box-shadow 0.3s;}
.popup-input::placeholder{color:rgba(255,255,255,0.3);}
.popup-input:focus{border-color:#00ffff;box-shadow:0 0 10px #00ffff44;}
.popup-btn{width:100%;padding:12px;border:1px solid #00ffff44;border-radius:8px;background:transparent;color:#00ffff;font-size:15px;font-weight:600;letter-spacing:3px;text-transform:uppercase;cursor:pointer;transition:box-shadow 0.3s,border-color 0.3s,color 0.3s,transform 0.2s;margin-top:6px;}
.popup-btn:hover{border-color:#00ffff;box-shadow:0 0 8px #00ffff,0 0 20px #00ffff88,inset 0 0 12px #00ffff22;color:#88ffff;transform:translateY(-2px);}
.contact-popup{background:#111;border:1px solid #ffffff22;border-radius:16px;padding:40px 36px;width:340px;display:flex;flex-direction:column;align-items:center;gap:18px;position:relative;box-shadow:0 0 40px #ffffff11,0 0 80px #00ffff11;transform:scale(0.9);transition:transform 0.3s;}
.popup-overlay.open .contact-popup{transform:scale(1);}
.contact-links{display:flex;flex-direction:column;width:100%;gap:10px;}
.contact-item{display:flex;align-items:center;gap:14px;padding:11px 16px;border-radius:10px;border:1px solid rgba(255,255,255,0.1);text-decoration:none;color:#fff;font-size:14px;font-weight:600;letter-spacing:2px;text-transform:uppercase;transition:border-color 0.3s,box-shadow 0.3s,color 0.3s,transform 0.2s;}
.contact-item:hover{border-color:var(--neon);box-shadow:0 0 8px #00ffff,0 0 20px #00ffff88,inset 0 0 12px #00ffff22;color:#88ffff;transform:translateY(-2px);}
.contact-icon{width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:var(--neon);flex-shrink:0;}
.contact-icon svg{width:22px;height:22px;}
.location-btn{display:flex;align-items:center;gap:10px;width:100%;padding:12px 16px;border-radius:10px;border:1px solid #ffffff33;background:transparent;color:#fff;font-size:13px;font-weight:600;letter-spacing:2px;text-transform:uppercase;text-decoration:none;justify-content:center;transition:border-color 0.3s,box-shadow 0.3s,color 0.3s,transform 0.2s;margin-top:4px;}
.location-btn:hover{border-color:#00ffff;box-shadow:0 0 8px #00ffff,0 0 20px #00ffff88,inset 0 0 12px #00ffff22;transform:translateY(-2px);}

/* PNG POPUP */
.png-overlay{position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.85);backdrop-filter:blur(8px);z-index:8500;display:flex;justify-content:center;align-items:center;opacity:0;pointer-events:none;transition:opacity 0.3s;}
.png-overlay.open{opacity:1;pointer-events:all;}
.png-popup{background:#0d0d0d;border:1px solid #00ff8833;border-radius:20px;padding:30px;width:90vw;max-width:1100px;height:80vh;display:flex;flex-direction:column;gap:16px;box-shadow:0 0 60px #00ff8822,0 0 120px #00ffff11;transform:scale(0.9);transition:transform 0.3s;position:relative;}
.png-overlay.open .png-popup{transform:scale(1);}
.png-popup-header{display:flex;justify-content:space-between;align-items:center;flex-shrink:0;}
.png-popup-title{font-size:22px;font-weight:800;letter-spacing:4px;text-transform:uppercase;background:linear-gradient(90deg,#00ff88,#00ffff);-webkit-background-clip:text;color:transparent;}
.png-popup-close{background:transparent;border:none;color:rgba(255,255,255,0.4);font-size:22px;cursor:pointer;transition:color 0.2s;flex-shrink:0;}
.png-popup-close:hover{color:#00ff88;}
.png-search{width:100%;background:#1a1a1a;border:1px solid #ffffff22;border-radius:10px;padding:12px 18px;font-size:14px;color:#fff;outline:none;transition:border-color 0.3s,box-shadow 0.3s;flex-shrink:0;}
.png-search::placeholder{color:rgba(255,255,255,0.3);}
.png-search:focus{border-color:#00ff88;box-shadow:0 0 10px #00ff8844;}
.png-grid{
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 4px;
  justify-content: center;
  align-content: start;
  flex: 1;
  min-height: 0;
  -webkit-overflow-scrolling: touch;
}
.png-grid::-webkit-scrollbar{width:5px;}
.png-grid::-webkit-scrollbar-track{background:#111;}
.png-grid::-webkit-scrollbar-thumb{background:#00ff8855;border-radius:10px;}
.png-card{
  background: #151515;
  border: 1px solid #ffffff11;
  border-radius: 14px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  width: 160px;
  min-width: 160px;
  max-width: 160px;
  flex-shrink: 0;
  cursor: pointer;
}
.png-card:hover{transform:translateY(-6px) scale(1.03);border-color:#00ff88;box-shadow:0 0 12px #00ff8866,0 0 30px #00ff8833,inset 0 0 20px #00ff8811;}
.png-card-img-wrap{width:100%;height:96px;min-height:96px;overflow:hidden;background:#1e1e1e;display:flex;align-items:center;justify-content:center;position:relative;}
.png-card-img-wrap img{max-width:90%;max-height:88px;width:auto;height:auto;object-fit:contain;transition:transform 0.4s;display:block;}
.png-card:hover .png-card-img-wrap img{transform:scale(1.12) rotate(2deg);}
.png-card-img-wrap::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.05) 0%,transparent 60%);opacity:0;transition:opacity 0.3s;pointer-events:none;}
.png-card:hover .png-card-img-wrap::after{opacity:1;}
.png-card-info{width:100%;padding:10px 12px;display:flex;flex-direction:column;align-items:center;}
.png-card-name{font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.7);text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;width:100%;}

/* SITE SEARCH */
.site-search-overlay{position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.85);backdrop-filter:blur(8px);z-index:9000;display:flex;justify-content:center;align-items:center;opacity:0;pointer-events:none;transition:opacity 0.3s;}
.site-search-overlay.open{opacity:1;pointer-events:all;}
.site-search-box{background:#0d0d0d;border:1px solid #4285f444;border-radius:20px;padding:30px;width:90vw;max-width:900px;height:80vh;display:flex;flex-direction:column;gap:16px;box-shadow:0 0 60px #4285f422;transform:scale(0.9);transition:transform 0.3s;position:relative;}
.site-search-overlay.open .site-search-box{transform:scale(1);}
.site-search-header{display:flex;justify-content:space-between;align-items:center;flex-shrink:0;}
.site-search-title{font-size:18px;font-weight:800;letter-spacing:3px;text-transform:uppercase;background:linear-gradient(90deg,#4285f4,#ea4335,#fbbc05,#34a853);-webkit-background-clip:text;color:transparent;}
.site-search-close{background:transparent;border:none;color:rgba(255,255,255,0.4);font-size:22px;cursor:pointer;transition:color 0.2s;}
.site-search-close:hover{color:#fff;}
.site-search-query{font-size:12px;letter-spacing:2px;color:rgba(255,255,255,0.3);text-transform:uppercase;flex-shrink:0;}
.site-search-results{overflow-y:auto;display:flex;flex-direction:column;gap:24px;padding-right:6px;flex:1;min-height:0;}
.site-search-results::-webkit-scrollbar{width:5px;}
.site-search-results::-webkit-scrollbar-thumb{background:#4285f455;border-radius:10px;}
.search-section-label{font-size:12px;letter-spacing:3px;text-transform:uppercase;margin-bottom:12px;text-shadow:0 0 8px currentColor;}
.search-mini-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,130px));gap:12px;justify-content:start;}
.search-mini-card{background:#151515;border:1px solid #ffffff11;border-radius:12px;overflow:hidden;display:flex;flex-direction:column;align-items:center;width:130px;transition:transform 0.3s,border-color 0.3s,box-shadow 0.3s;}
.search-mini-card:hover{transform:translateY(-5px);border-color:#00ff88;box-shadow:0 0 12px #00ff8866;}
.search-mini-img{width:100%;height:90px;background:#1e1e1e;display:flex;align-items:center;justify-content:center;cursor:pointer;overflow:hidden;}
.search-mini-img img{max-width:90%;max-height:82px;object-fit:contain;}
.search-mini-info{padding:8px;width:100%;display:flex;flex-direction:column;align-items:center;gap:6px;}
.search-mini-name{font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.7);text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;width:100%;}
.search-mini-dl{width:100%;padding:6px;border:1px solid #00ff8844;border-radius:7px;background:transparent;color:#00ff88;font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;text-decoration:none;text-align:center;display:block;transition:box-shadow 0.3s,background 0.3s;}
.search-mini-dl:hover{background:#00ff8815;box-shadow:0 0 10px #00ff88;}
.search-portfolio-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,150px));gap:12px;justify-content:start;}
.search-port-card{background:#151515;border:1px solid #ffffff11;border-radius:12px;overflow:hidden;width:150px;transition:transform 0.3s,border-color 0.3s,box-shadow 0.3s;}
.search-port-card:hover{transform:translateY(-5px);border-color:#00ffff;box-shadow:0 0 12px #00ffff66;}
.search-port-img{width:100%;height:110px;overflow:hidden;background:#1e1e1e;}
.search-port-img img{width:100%;height:100%;object-fit:cover;}
.search-port-info{padding:10px;text-align:center;}
.search-port-name{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.7);}
.search-port-type{font-size:9px;letter-spacing:1px;color:#00ffff;margin-top:3px;}
.search-no-result{text-align:center;padding:60px 20px;color:rgba(255,255,255,0.25);letter-spacing:3px;font-size:13px;text-transform:uppercase;}

/* HERO */
.hero{height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;position:relative;}
.hero h1{font-size:140px;letter-spacing:10px;font-weight:900;background:linear-gradient(180deg,#ffffff,#cfcfcf,#ffffff);-webkit-background-clip:text;color:transparent;text-shadow:0 1px 0 #bbb,0 2px 0 #aaa,0 3px 0 #999,0 4px 0 #888,0 5px 0 #777;transition:.4s;}
.hero h1:hover{animation:glitch .5s infinite;text-shadow:2px 2px #ff0055,-2px -2px #00ffff,0 0 20px white;}
@keyframes glitch{0%{transform:translate(0)}20%{transform:translate(-2px,2px)}40%{transform:translate(-2px,-2px)}60%{transform:translate(2px,2px)}80%{transform:translate(2px,-2px)}100%{transform:translate(0)}}
.character{position:absolute;top:15%;width:480px;z-index:3;pointer-events:none;}
.hero p{margin-top:220px;font-size:30px;opacity:.7;}

.category-buttons{display:flex;gap:16px;justify-content:center;margin-top:35px;flex-wrap:wrap;}
.cat-btn{position:relative;background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.25);border-radius:8px;padding:10px 28px;font-size:15px;font-weight:600;letter-spacing:2px;text-transform:uppercase;cursor:pointer;overflow:hidden;transition:color 0.3s,border-color 0.3s,box-shadow 0.3s,transform 0.2s;backdrop-filter:blur(6px);}
.cat-btn::before{content:'';position:absolute;inset:0;background:currentColor;opacity:0;transform:scaleX(0);transform-origin:left;transition:transform 0.35s ease,opacity 0.35s ease;z-index:0;}
.cat-btn:hover::before{transform:scaleX(1);opacity:0.12;}
.cat-btn:nth-child(1){color:#ff00ff;border-color:#ff00ff44;}
.cat-btn:nth-child(1):hover{border-color:#ff00ff;box-shadow:0 0 8px #ff00ff,0 0 20px #ff00ff88,0 0 40px #ff00ff44,inset 0 0 12px #ff00ff22;color:#ff88ff;transform:translateY(-3px);}
.cat-btn:nth-child(2){color:#00ffff;border-color:#00ffff44;}
.cat-btn:nth-child(2):hover{border-color:#00ffff;box-shadow:0 0 8px #00ffff,0 0 20px #00ffff88,0 0 40px #00ffff44,inset 0 0 12px #00ffff22;color:#88ffff;transform:translateY(-3px);}
.cat-btn:nth-child(3){color:#ff6600;border-color:#ff660044;}
.cat-btn:nth-child(3):hover{border-color:#ff6600;box-shadow:0 0 8px #ff6600,0 0 20px #ff660088,0 0 40px #ff660044,inset 0 0 12px #ff660022;color:#ffaa66;transform:translateY(-3px);}
.cat-btn:nth-child(4){color:#00ff88;border-color:#00ff8844;}
.cat-btn:nth-child(4):hover{border-color:#00ff88;box-shadow:0 0 8px #00ff88,0 0 20px #00ff8888,0 0 40px #00ff8844,inset 0 0 12px #00ff8822;color:#88ffcc;transform:translateY(-3px);}
.cat-btn:active{transform:translateY(0px) scale(0.97);}

.search-container{margin-top:35px;display:flex;flex-direction:column;align-items:center;gap:18px;}
.search-box-wrapper{position:relative;border-radius:26px;padding:2px;background:transparent;transition:box-shadow 0.3s;width:550px;max-width:92vw;}
.search-box-wrapper.active{background:linear-gradient(90deg,#4285f4,#ea4335,#fbbc05,#34a853,#4285f4);background-size:300% 300%;animation:gradientRun 2s linear infinite;box-shadow:0 0 18px rgba(66,133,244,0.35);}
@keyframes gradientRun{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
.google-search-box{display:flex;align-items:center;background:#fff;border-radius:24px;padding:0 14px;width:100%;height:48px;cursor:text;}
.search-icon-left{width:20px;height:20px;fill:#9aa0a6;flex-shrink:0;}
.google-search-input{flex:1;border:none;outline:none;font-size:16px;color:#222;background:transparent;padding:0 12px;height:100%;font-family:arial,sans-serif;}
.google-search-input::placeholder{color:#9aa0a6;}
.search-right-icons{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.voice-icon,.lens-icon{width:22px;height:22px;cursor:pointer;opacity:0.8;transition:opacity 0.2s,transform 0.2s;}
.voice-icon:hover,.lens-icon:hover{opacity:1;transform:scale(1.15);}
.google-search-buttons{display:flex;gap:20px;}
.gsearch-btn-wrapper{position:relative;border-radius:25px;padding:2px;background:#e8eaed;transition:background 0.3s,box-shadow 0.3s;}
.gsearch-btn-wrapper:hover{background:linear-gradient(90deg,#4285f4,#ea4335,#fbbc05,#34a853,#4285f4);background-size:300% 300%;animation:gradientRun 2s linear infinite;box-shadow:0 0 12px rgba(66,133,244,0.3);}
.gsearch-btn{display:block;background:#f8f9fa;color:#3c4043;border:none;border-radius:25px;padding:7px 15px;font-size:20px;cursor:pointer;font-family:arial,sans-serif;transition:color 0.2s;white-space:nowrap;}
.gsearch-btn:hover{color:#1a1a1a;}

section{padding:120px 10%;}
.title{font-size:40px;margin-bottom:50px;}
.work-grid{display:grid;height:350px;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:10px;}
.work{position:relative;overflow:hidden;border-radius:10px;}
.work img{width:100%;height:100%;display:block;transition:.3s;}
.work:hover img{transform:scale(1.1);}
.overlay{position:absolute;bottom:0;left:0;right:0;text-align:center;background:rgba(0,0,0,0.7);padding:8px;transform:translateY(100%); color:White;transition:.3s;}
.work:hover .overlay{transform:translateY(0);}
.about{max-width:700px;line-height:1.7;opacity:.8;}
footer{text-align:center;padding:40px;opacity:.5;}

 

@media(max-width:768px){
  .home-btn{width:55px;top:15px;left:15px;}
  .menu-btn{width:55px;top:15px;right:15px;}
  .menu-dropdown{top:85px;right:15px;gap:8px;}
